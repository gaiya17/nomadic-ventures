generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admin_users {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  name          String    @db.VarChar(100)
  role          String?   @default("admin") @db.VarChar(50)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  last_login    DateTime? @db.Timestamptz(6)
}

model ResortCategory {
  id          String                  @id @default(uuid())
  name        String                  @unique
  slug        String                  @unique
  description String?
  whatDefines String?
  resorts     ResortCategoryMapping[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
}

model TourCategory {
  id           String                @id @default(uuid())
  name         String                @unique
  slug         String                @unique
  description  String?
  destinations String?
  image        String?
  tours        TourCategoryMapping[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model Resort {
  id             String                  @id @default(uuid())
  name           String
  slug           String                  @unique
  description    String?                 
  location       String?
  transferMethod String?
  duration       String?
  price          String?
  stars          Int                     @default(5)
  status         String                  @default("DRAFT")
  
  categories     ResortCategoryMapping[]
  villas         ResortVilla[]
  restaurants    ResortRestaurant[]
  media          ResortMedia[]
  facilities     ResortFacility[]
  
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model ResortCategoryMapping {
  id         String         @id @default(uuid())
  resortId   String
  categoryId String
  resort     Resort         @relation(fields: [resortId], references: [id], onDelete: Cascade)
  category   ResortCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([resortId, categoryId])
}

model ResortMedia {
  id        String   @id @default(uuid())
  resortId  String
  type      String   // e.g., 'hero', 'card', 'gallery'
  url       String
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ResortVilla {
  id          String   @id @default(uuid())
  resortId    String
  title       String
  bedType     String?
  description String?  
  roomSize    String?
  capacities  String?  // JSON string
  features    String?  // JSON string
  images      String?  // JSON string
  resort      Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResortRestaurant {
  id          String   @id @default(uuid())
  resortId    String
  name        String
  description String?  
  image       String?
  timings     String?  // JSON string
  resort      Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResortFacility {
  id           String   @id @default(uuid())
  resortId     String
  facilityName String
  resort       Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
}

model Tour {
  id           String                @id @default(uuid())
  name         String
  slug         String                @unique
  description  String?
  guests       String?
  days         String?
  destinations String?
  price        String?
  status       String                @default("DRAFT")
  includes     String?               // JSON string array
  excludes     String?               // JSON string array
  experiences  String?               // JSON string array

  categories   TourCategoryMapping[]
  media        TourMedia[]
  itineraries  TourItinerary[]

  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model TourCategoryMapping {
  id         String       @id @default(uuid())
  tourId     String
  categoryId String
  tour       Tour         @relation(fields: [tourId], references: [id], onDelete: Cascade)
  category   TourCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([tourId, categoryId])
}

model TourMedia {
  id        String   @id @default(uuid())
  tourId    String
  type      String   // 'hero', 'card', 'gallery'
  url       String
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TourItinerary {
  id          String   @id @default(uuid())
  tourId      String
  title       String
  description String?
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  locationPlace   String?
  locationCountry String?
  tagline         String?
  bestTimeStart   String?
  bestTimeEnd     String?
  highlights      String?
  contentBlocks   String?
  gallery         String?
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
