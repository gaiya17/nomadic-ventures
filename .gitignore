# ── Dependencies (NEVER commit these) ──────────────────────────────────────
node_modules/
.pnpm-store/

# ── Next.js build output ─────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/

# ── Backend build output (keep until backend folder is fully retired) ────────
backend/dist/
backend/build/

# ── Prisma generated client (regenerated on every install via postinstall) ───
frontend/node_modules/.prisma/

# ── Environment variables (NEVER commit these — contains secrets!) ──────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS generated files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE files ────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Uploads (local disk — replaced by Cloudinary in production) ──────────────
backend/uploads/
frontend/uploads/
